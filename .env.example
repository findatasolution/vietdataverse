# .env.example — required environment variables (real values live in the root .env, never committed).
# This file documents keys added by the fuel-forecast feature. The backend also reads the
# existing DB/R2/Auth0/SMTP keys already provisioned in .env (not duplicated here).

# --- Fuel-forecast product (Plan 1) ------------------------------------------
FUEL_FORECAST_DB=postgresql://user:pass@host/fuel_forecast?sslmode=require  # isolated Neon DB (fuel_* tables)
R2_BUCKET_RAW=vdv-raw   # Cloudflare R2 bucket for the Bronze landing zone (raw immutable payloads)

# The corporate API service (Plan 4) does NOT use this file — it loads its own
# secrets from .corp-prod-env (separate, higher-isolation). See docs/research/fuel-price-forecast-design.md §7.
